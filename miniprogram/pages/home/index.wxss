.home-page {
  background: #fef9ef;
  min-height: 100vh;
  padding: 20rpx 32rpx 40rpx;
}

/* ── Mood banner ── */
.mood-banner {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.mood-pill {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.mood-pill.mood-sleepy  { background: #e8e0f0; color: #5a4580; }
.mood-pill.mood-bright  { background: #fff3d8; color: #b8860b; }
.mood-pill.mood-quiet   { background: #e3eff5; color: #3e6b89; }
.mood-pill.mood-waiting { background: #f5ede3; color: #8b6f47; }
.mood-pill.mood-messy   { background: #fde8e8; color: #9b4b4b; }
.mood-pill.mood-cozy    { background: #f0e6dd; color: #a0522d; }

.mood-emoji { font-size: 26rpx; }
.mood-label { font-size: 26rpx; }

.mood-text {
  color: #5a6658;
  font-size: 28rpx;
  line-height: 1.4;
}

/* ── Pet room ── */
.pet-room {
  position: relative;
  margin-top: 8rpx;
  min-height: 580rpx;
  overflow: hidden;
  border-radius: 36rpx;
  background:
    linear-gradient(180deg, rgba(255,251,239,0.96), rgba(245,225,190,0.7));
}

.pet-main {
  position: absolute;
  left: 50%;
  top: 20rpx;
  z-index: 1;
  width: 520rpx;
  height: 440rpx;
  transform: translateX(-50%);
  animation: pet-breathe 3.4s ease-in-out infinite;
}

.pet-shadow {
  position: absolute;
  left: 50%;
  bottom: 60rpx;
  width: 260rpx;
  height: 36rpx;
  border-radius: 50%;
  background: rgba(50,37,24,0.08);
  transform: translateX(-50%);
}

@keyframes pet-breathe {
  0%, 100% { transform: translateX(-50%) translateY(0) scale(1); }
  50% { transform: translateX(-50%) translateY(-8rpx) scale(1.015); }
}

.narration {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  bottom: 120rpx;
  z-index: 2;
  padding: 18rpx 22rpx;
  border-radius: 18rpx;
  background: rgba(255,249,236,0.92);
  color: #3a4a38;
  font-size: 26rpx;
  line-height: 1.5;
}

/* ── Stats ── */
.stats-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0;
  margin-top: 20rpx;
  padding: 18rpx 32rpx;
  border-radius: 20rpx;
  background: #fffdf5;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  flex: 1;
}

.stat-label {
  color: #8a9a85;
  font-size: 22rpx;
}

.stat-value {
  color: #14422d;
  font-size: 28rpx;
  font-weight: 700;
}

.stat-divider {
  width: 1rpx;
  height: 40rpx;
  background: #dce6df;
}

/* ── Today event card ── */
.event-card {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 16rpx;
  padding: 18rpx 22rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #fef7e6, #fcf0d8);
  border: 1rpx solid #f0e0c0;
}

.event-emoji {
  font-size: 36rpx;
  flex-shrink: 0;
}

.event-text {
  color: #5a4528;
  font-size: 26rpx;
  line-height: 1.45;
}

/* ── Memory card ── */
.memory-card {
  margin-top: 16rpx;
  padding: 20rpx 22rpx;
  border-radius: 18rpx;
  background: #fffdf5;
  border: 1rpx solid #ece4cf;
}

.memory-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  color: #47613e;
  font-size: 24rpx;
  font-weight: 800;
}

.memory-time {
  flex-shrink: 0;
  color: #9aa38e;
  font-size: 20rpx;
  font-weight: 500;
}

.memory-text {
  margin-top: 10rpx;
  color: #2f3b2d;
  font-size: 27rpx;
  line-height: 1.45;
}

/* ── Care status chips ── */
.care-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.care-chip {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #edf2ed;
  color: #7a8a7a;
  font-size: 22rpx;
}

.care-chip.done {
  background: #dcecdc;
  color: #2e5a2e;
  font-weight: 600;
}

/* ── Actions ── */
.today-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 24rpx;
}

.action-card {
  margin: 0;
  min-height: 120rpx;
  padding: 22rpx;
  border-radius: 20rpx;
  background: #fffdf5;
  color: #14422d;
  text-align: left;
}

.action-title {
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.3;
}

.action-sub {
  margin-top: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
  line-height: 1.35;
  opacity: 0.65;
}

/* ── Visits ── */
.visits {
  margin-top: 24rpx;
}

.section-title {
  margin-bottom: 16rpx;
  color: #14422d;
  font-size: 30rpx;
  font-weight: 700;
}

.visit-row {
  padding: 16rpx 0;
  border-top: 1rpx solid #e8efe8;
}

.muted {
  color: #8a9a85;
  font-size: 22rpx;
}

/* ── Card ── */
.card {
  padding: 28rpx;
  border-radius: 24rpx;
  background: #fffdf5;
}
