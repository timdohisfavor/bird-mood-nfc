.logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 999rpx;
  background: #dde7e1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 72rpx;
  margin-bottom: 36rpx;
}

.logo-mark {
  width: 70rpx;
  height: 96rpx;
  border-radius: 70rpx 70rpx 70rpx 18rpx;
  background: #14422d;
  transform: rotate(32deg);
  box-shadow: -20rpx 22rpx 0 #f2d8a8;
}

.actions {
  width: 100%;
  margin-top: 72rpx;
}

.subtitle-text {
  white-space: pre-line;
}

.buy-tip {
  margin-top: 40rpx;
  color: #8a968f;
  font-size: 24rpx;
  line-height: 1.6;
}
