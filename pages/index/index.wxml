<view class="page">
  <view class="habitat-bg">
    <view class="habitat-sky"></view>
    <view class="habitat-sun"></view>
    <view class="habitat-ridge ridge-back"></view>
    <view class="habitat-ridge ridge-front"></view>
    <view class="habitat-water"></view>
    <view class="habitat-forest forest-left"></view>
    <view class="habitat-forest forest-right"></view>
    <view class="habitat-reeds reeds-left"></view>
    <view class="habitat-reeds reeds-right"></view>
  </view>

  <view wx:if="{{currentScreen === 'home'}}" class="screen">
    <view class="hero">
      <view>
        <text class="ghost-title">BIRD HABITAT</text>
        <text class="eyebrow">NFC 已唤醒</text>
        <text class="title">今日鸟签</text>
        <text class="subcopy">每天碰一下，让一只鸟替你描述精神状态。</text>
      </view>
      <button class="nfc-pill" bindtap="bindStand">
        <view class="nfc-dot"></view>
        <text>{{bound ? '已绑定' : '绑定支架'}}</text>
      </button>
    </view>

    <view class="companion">
      <view class="bird-orb">
        <image wx:if="{{homeBird.image}}" class="bird-photo" src="{{homeBird.image}}" mode="aspectFit" />
        <view wx:else class="bird-shape {{homeBird.featureClass}}" style="{{homeBird.birdStyle}}">
          <view class="bird-tail"></view>
          <view class="bird-body"></view>
          <view class="bird-belly"></view>
          <view class="bird-leg left"></view>
          <view class="bird-leg right"></view>
          <view class="bird-head"></view>
          <view class="bird-face"></view>
          <view class="bird-crown"></view>
          <view class="bird-throat"></view>
          <view class="bird-eye"></view>
          <view class="bird-beak"></view>
          <view class="bird-wing"></view>
          <view class="bird-mark one"></view>
          <view class="bird-mark two"></view>
          <view class="bird-mark three"></view>
        </view>
      </view>
      <view class="companion-copy">
        <text class="tag">你的本命鸟</text>
        <text class="bird-name">{{homeBird.name}}</text>
        <text class="bird-line">{{homeBird.line}}</text>
      </view>
    </view>

    <view class="daily-card">
      <text class="card-watermark">FOREST · WETLAND · PARK</text>
      <view class="card-top">
        <text>{{todayText}}</text>
        <text class="rarity">{{activeBird.rarity}}</text>
      </view>
      <view class="bird-portrait">
        <image wx:if="{{activeBird.image}}" class="bird-photo large-photo" src="{{activeBird.image}}" mode="aspectFit" />
        <view wx:else class="bird-shape large {{activeBird.featureClass}}" style="{{activeBird.birdStyle}}">
          <view class="bird-tail"></view>
          <view class="bird-body"></view>
          <view class="bird-belly"></view>
          <view class="bird-leg left"></view>
          <view class="bird-leg right"></view>
          <view class="bird-head"></view>
          <view class="bird-face"></view>
          <view class="bird-crown"></view>
          <view class="bird-throat"></view>
          <view class="bird-eye"></view>
          <view class="bird-beak"></view>
          <view class="bird-wing"></view>
          <view class="bird-mark one"></view>
          <view class="bird-mark two"></view>
          <view class="bird-mark three"></view>
        </view>
      </view>
      <view class="rank-row">
        <text>小红书热度 No.{{activeBird.rank}}</text>
        <text>{{activeBird.heat}}</text>
      </view>
      <text class="state-label">今日精神状态</text>
      <text class="daily-name">{{activeBird.name}}</text>
      <text class="look-line">{{activeBird.look}}</text>
      <text class="quote">{{activeBird.quote}}</text>
      <view class="meter-grid">
        <view class="meter">
          <text>摸鱼指数</text>
          <text class="stars">{{activeBird.fishText}}</text>
        </view>
        <view class="meter">
          <text>社交电量</text>
          <text class="stars">{{activeBird.socialText}}</text>
        </view>
        <view class="meter">
          <text>开会耐受</text>
          <text class="stars">{{activeBird.meetingText}}</text>
        </view>
      </view>
      <button class="primary" bindtap="drawBird">翻开今日鸟签</button>
    </view>

    <view class="micro-actions">
      <button bindtap="collectActiveBird">收进鸟窝</button>
      <button data-screen="poster" bindtap="goScreen">生成分享图</button>
      <button data-screen="nest" bindtap="goScreen">查看图鉴</button>
    </view>
  </view>

  <view wx:if="{{currentScreen === 'nest'}}" class="screen">
    <view class="page-head">
      <button class="icon-btn" data-screen="home" bindtap="goScreen">‹</button>
      <view>
        <text class="ghost-title small-ghost">FIELD GUIDE</text>
        <text class="eyebrow">Top30 鸟签库</text>
        <text class="title small">每只鸟一张签</text>
      </view>
    </view>
    <view class="progress-card">
      <view class="progress-row">
        <text>已收录鸟签</text>
        <text class="progress-count">{{birds.length}} / 30</text>
      </view>
      <view class="progress-track">
        <view class="progress-fill" style="width: 100%;"></view>
      </view>
    </view>
    <view class="collection">
      <view wx:for="{{collectionCards}}" wx:key="id" class="bird-tile" data-id="{{item.id}}" bindtap="selectBird">
        <view class="tile-rank">No.{{item.rank}} · {{item.heat}}</view>
        <view class="bird-mini">
          <image wx:if="{{item.image}}" class="bird-photo mini-photo" src="{{item.image}}" mode="aspectFit" />
          <view wx:else class="bird-shape small {{item.featureClass}}" style="{{item.birdStyle}}">
            <view class="bird-tail"></view>
            <view class="bird-body"></view>
            <view class="bird-belly"></view>
            <view class="bird-leg left"></view>
            <view class="bird-leg right"></view>
            <view class="bird-head"></view>
            <view class="bird-face"></view>
            <view class="bird-crown"></view>
            <view class="bird-throat"></view>
            <view class="bird-eye"></view>
            <view class="bird-beak"></view>
            <view class="bird-wing"></view>
            <view class="bird-mark one"></view>
            <view class="bird-mark two"></view>
            <view class="bird-mark three"></view>
          </view>
        </view>
        <text class="tile-title">{{item.name}}</text>
        <text class="tile-look">{{item.look}}</text>
        <text class="tile-copy">{{item.quote}}</text>
      </view>
    </view>
  </view>

  <view wx:if="{{currentScreen === 'poster'}}" class="screen">
    <view class="page-head">
      <button class="icon-btn" data-screen="home" bindtap="goScreen">‹</button>
      <view>
        <text class="ghost-title small-ghost">DAILY POSTER</text>
        <text class="eyebrow">分享海报</text>
        <text class="title small">把今天发给朋友</text>
      </view>
    </view>
    <view class="poster">
      <text class="poster-brand">BIRD MOOD CLUB</text>
      <view class="poster-art">
        <image wx:if="{{activeBird.image}}" class="bird-photo poster-photo" src="{{activeBird.image}}" mode="aspectFit" />
        <view wx:else class="bird-shape poster-bird {{activeBird.featureClass}}" style="{{activeBird.birdStyle}}">
          <view class="bird-tail"></view>
          <view class="bird-body"></view>
          <view class="bird-belly"></view>
          <view class="bird-leg left"></view>
          <view class="bird-leg right"></view>
          <view class="bird-head"></view>
          <view class="bird-face"></view>
          <view class="bird-crown"></view>
          <view class="bird-throat"></view>
          <view class="bird-eye"></view>
          <view class="bird-beak"></view>
          <view class="bird-wing"></view>
          <view class="bird-mark one"></view>
          <view class="bird-mark two"></view>
          <view class="bird-mark three"></view>
        </view>
      </view>
      <text class="poster-kicker">今日精神状态</text>
      <text class="poster-title">{{activeBird.name}}</text>
      <text class="poster-look">No.{{activeBird.rank}} · {{activeBird.heat}} · {{activeBird.look}}</text>
      <text class="poster-quote">{{activeBird.quote}}</text>
      <view class="poster-foot">
        <text>NFC 鸟签</text>
        <text>碰一下，抽今天</text>
      </view>
    </view>
    <button class="primary ghost" bindtap="savePoster">保存海报预览</button>
  </view>

  <view class="tabbar">
    <button class="tab {{currentScreen === 'home' ? 'active' : ''}}" data-screen="home" bindtap="goScreen">今日</button>
    <button class="tab {{currentScreen === 'nest' ? 'active' : ''}}" data-screen="nest" bindtap="goScreen">鸟窝</button>
    <button class="tab {{currentScreen === 'poster' ? 'active' : ''}}" data-screen="poster" bindtap="goScreen">分享</button>
  </view>
</view>
