.page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  background:
    linear-gradient(180deg, rgba(238, 245, 241, 0.96) 0%, rgba(248, 250, 247, 0.94) 52%, rgba(229, 238, 226, 0.96) 100%);
  padding: 32rpx 32rpx calc(148rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.screen {
  position: relative;
  z-index: 2;
  display: block;
}

.habitat-bg {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 0;
  pointer-events: none;
  overflow: hidden;
}

.habitat-sky {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background:
    radial-gradient(circle at 72% 12%, rgba(255, 255, 255, 0.92) 0 10%, transparent 28%),
    linear-gradient(180deg, #e9f2f4 0%, #f8faf7 46%, #dbe8dc 100%);
}

.habitat-sun {
  position: absolute;
  right: 76rpx;
  top: 170rpx;
  width: 136rpx;
  height: 136rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.78);
  filter: blur(6rpx);
}

.habitat-ridge {
  position: absolute;
  left: -18%;
  right: -18%;
  height: 360rpx;
  border-radius: 50% 50% 0 0;
  transform: rotate(-4deg);
}

.ridge-back {
  bottom: 184rpx;
  background: linear-gradient(145deg, rgba(176, 204, 177, 0.45), rgba(102, 150, 112, 0.2));
}

.ridge-front {
  bottom: 82rpx;
  height: 300rpx;
  background: linear-gradient(145deg, rgba(87, 135, 80, 0.55), rgba(205, 224, 196, 0.34));
  transform: rotate(5deg);
}

.habitat-water {
  position: absolute;
  left: -10%;
  right: -10%;
  bottom: -70rpx;
  height: 254rpx;
  background:
    linear-gradient(180deg, rgba(167, 199, 186, 0.04), rgba(91, 139, 126, 0.32)),
    repeating-linear-gradient(170deg, rgba(255, 255, 255, 0.2) 0 8rpx, transparent 8rpx 28rpx);
  border-radius: 50% 50% 0 0;
}

.habitat-forest,
.habitat-reeds {
  position: absolute;
  bottom: 18rpx;
  opacity: 0.56;
}

.habitat-forest {
  width: 300rpx;
  height: 260rpx;
  background:
    radial-gradient(ellipse at 22% 70%, rgba(26, 75, 39, 0.6) 0 16%, transparent 17%),
    radial-gradient(ellipse at 44% 56%, rgba(58, 107, 49, 0.72) 0 17%, transparent 18%),
    radial-gradient(ellipse at 68% 64%, rgba(36, 91, 52, 0.66) 0 15%, transparent 16%),
    linear-gradient(180deg, transparent 0 54%, rgba(32, 87, 45, 0.36) 55% 100%);
  filter: blur(1rpx);
}

.forest-left {
  left: -72rpx;
}

.forest-right {
  right: -110rpx;
  transform: scale(1.15);
}

.habitat-reeds {
  width: 220rpx;
  height: 260rpx;
  background:
    linear-gradient(80deg, transparent 0 45%, rgba(34, 89, 44, 0.5) 46% 48%, transparent 49%),
    linear-gradient(96deg, transparent 0 38%, rgba(74, 119, 65, 0.5) 39% 41%, transparent 42%),
    linear-gradient(108deg, transparent 0 58%, rgba(31, 81, 41, 0.42) 59% 61%, transparent 62%),
    linear-gradient(72deg, transparent 0 24%, rgba(101, 133, 70, 0.5) 25% 27%, transparent 28%);
}

.reeds-left {
  left: 18rpx;
}

.reeds-right {
  right: 26rpx;
  transform: scaleX(-1);
}

.hero,
.page-head {
  position: relative;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 22rpx;
}

.hero > view,
.page-head > view,
.nfc-pill,
.icon-btn {
  position: relative;
  z-index: 1;
}

.hero {
  min-height: 292rpx;
  padding-top: 20rpx;
}

.ghost-title {
  position: absolute;
  left: -4rpx;
  top: -10rpx;
  z-index: 0;
  width: 680rpx;
  color: rgba(20, 47, 29, 0.07);
  font-size: 86rpx;
  font-weight: 900;
  line-height: 0.9;
  white-space: nowrap;
}

.small-ghost {
  top: 8rpx;
  font-size: 62rpx;
}

.eyebrow {
  display: block;
  margin-bottom: 10rpx;
  color: #2f6f3e;
  font-size: 24rpx;
  font-weight: 800;
}

.title {
  display: block;
  color: #121512;
  font-size: 56rpx;
  font-weight: 900;
  line-height: 1.08;
}

.title.small {
  font-size: 44rpx;
}

.subcopy {
  display: block;
  width: 430rpx;
  margin-top: 16rpx;
  color: #6f756d;
  font-size: 28rpx;
  line-height: 1.55;
}

.nfc-pill {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 64rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  color: #ffffff;
  background: #142f1d;
  font-size: 24rpx;
  font-weight: 800;
  line-height: normal;
  white-space: nowrap;
}

.nfc-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #8dbb6e;
  box-shadow: 0 0 0 10rpx rgba(141, 187, 110, 0.22);
}

.companion {
  display: grid;
  grid-template-columns: 210rpx 1fr;
  gap: 28rpx;
  align-items: center;
  margin: -26rpx 0 28rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.58);
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.78);
  box-shadow: 0 18rpx 42rpx rgba(20, 47, 29, 0.1);
  backdrop-filter: blur(18rpx);
}

.bird-orb,
.bird-portrait,
.poster-art,
.bird-mini {
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: visible;
  border-radius: 0;
  background: transparent;
}

.bird-photo {
  display: block;
  width: 100%;
  height: 100%;
  filter: drop-shadow(0 18rpx 24rpx rgba(0, 0, 0, 0.16));
}

.large-photo {
  width: 100%;
  height: 100%;
}

.mini-photo {
  width: 100%;
  height: 100%;
}

.poster-photo {
  width: 100%;
  height: 100%;
}

.bird-orb {
  width: 206rpx;
  height: 206rpx;
}

.bird-portrait {
  width: 390rpx;
  height: 390rpx;
  margin: 4rpx auto 18rpx;
}

.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 14rpx;
  min-height: 44rpx;
  padding: 10rpx 16rpx;
  box-sizing: border-box;
  border-radius: 999rpx;
  color: #ffffff;
  background: #2f6f3e;
  font-size: 22rpx;
  font-weight: 800;
  line-height: normal;
}

.bird-name {
  display: block;
  color: #121512;
  font-size: 42rpx;
  font-weight: 900;
}

.bird-line {
  display: block;
  margin-top: 12rpx;
  color: #6f756d;
  font-size: 27rpx;
  line-height: 1.45;
}

.daily-card {
  position: relative;
  overflow: hidden;
  padding: 32rpx;
  border: 1rpx solid rgba(20, 47, 29, 0.12);
  border-radius: 40rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.94), rgba(250, 252, 247, 0.9)),
    radial-gradient(circle at 20% 0%, rgba(141, 187, 110, 0.18), transparent 34%);
  box-shadow: 0 22rpx 52rpx rgba(20, 47, 29, 0.12);
}

.card-watermark {
  position: absolute;
  left: 22rpx;
  right: 22rpx;
  top: 104rpx;
  color: rgba(20, 47, 29, 0.055);
  text-align: center;
  font-size: 56rpx;
  font-weight: 900;
  white-space: nowrap;
}

.card-top,
.progress-row,
.poster-foot {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-top {
  position: relative;
  z-index: 1;
  color: #6f756d;
  font-size: 26rpx;
  font-weight: 800;
}

.rarity {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 50rpx;
  padding: 10rpx 18rpx;
  box-sizing: border-box;
  border-radius: 999rpx;
  color: #ffffff;
  background: #142f1d;
  line-height: normal;
  white-space: nowrap;
}

.state-label,
.poster-kicker {
  display: block;
  color: #2f6f3e;
  text-align: center;
  font-size: 26rpx;
  font-weight: 800;
}

.daily-name {
  display: block;
  margin-top: 10rpx;
  color: #121512;
  text-align: center;
  font-size: 52rpx;
  font-weight: 900;
}

.quote {
  display: block;
  min-height: 92rpx;
  margin: 18rpx auto 26rpx;
  color: #3f463d;
  text-align: center;
  font-size: 31rpx;
  line-height: 1.55;
}

.rank-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 4rpx 0 18rpx;
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
  color: #6f756d;
  background: rgba(238, 245, 241, 0.86);
  font-size: 24rpx;
  font-weight: 800;
}

.look-line {
  display: block;
  margin-top: 8rpx;
  color: #2f6f3e;
  text-align: center;
  font-size: 24rpx;
  font-weight: 800;
}

.meter-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-bottom: 28rpx;
}

.meter {
  min-height: 118rpx;
  padding: 18rpx 10rpx;
  border: 1rpx solid rgba(20, 47, 29, 0.1);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.74);
  text-align: center;
  box-sizing: border-box;
}

.meter text:first-child {
  display: block;
  color: #6f756d;
  font-size: 21rpx;
}

.stars {
  display: block;
  margin-top: 12rpx;
  color: #2f6f3e;
  font-size: 27rpx;
  font-weight: 900;
}

.primary {
  width: 100%;
  height: 94rpx;
  border-radius: 18rpx;
  color: #ffffff;
  background: #142f1d;
  font-size: 31rpx;
  font-weight: 900;
  line-height: normal;
  white-space: nowrap;
}

.primary.ghost {
  margin-top: 28rpx;
  color: #121512;
  background: rgba(255, 255, 255, 0.92);
}

.micro-actions {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-top: 24rpx;
}

.micro-actions button {
  height: 82rpx;
  border: 1rpx solid rgba(20, 47, 29, 0.12);
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.84);
  color: #121512;
  font-size: 25rpx;
  font-weight: 800;
  line-height: normal;
  white-space: nowrap;
}

.icon-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  color: #121512;
  background: rgba(255, 255, 255, 0.9);
  font-size: 44rpx;
  font-weight: 500;
  line-height: normal;
}

.progress-card {
  margin: 34rpx 0 28rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(20, 47, 29, 0.12);
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.88);
  box-shadow: 0 14rpx 36rpx rgba(20, 47, 29, 0.08);
}

.progress-row {
  color: #6f756d;
  font-size: 26rpx;
}

.progress-count {
  color: #121512;
  font-weight: 900;
}

.progress-track {
  height: 18rpx;
  margin-top: 22rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: rgba(20, 47, 29, 0.1);
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #8dbb6e, #2f6f3e);
}

.collection {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.bird-tile {
  min-height: 468rpx;
  padding: 22rpx;
  border: 1rpx solid rgba(20, 47, 29, 0.12);
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 10rpx 28rpx rgba(20, 47, 29, 0.08);
  box-sizing: border-box;
}

.bird-tile.locked {
  opacity: 0.52;
  filter: grayscale(1);
}

.bird-mini {
  width: 226rpx;
  height: 226rpx;
  margin: 8rpx auto 14rpx;
}

.tile-rank {
  color: #2f6f3e;
  text-align: center;
  font-size: 22rpx;
  font-weight: 900;
}

.tile-title {
  display: block;
  color: #121512;
  text-align: center;
  font-size: 30rpx;
  font-weight: 900;
}

.tile-copy {
  display: block;
  margin-top: 12rpx;
  color: #6f756d;
  text-align: center;
  font-size: 23rpx;
  line-height: 1.45;
}

.tile-look {
  display: block;
  margin-top: 8rpx;
  color: #2f6f3e;
  text-align: center;
  font-size: 22rpx;
  font-weight: 800;
}

.poster {
  min-height: 900rpx;
  margin-top: 34rpx;
  padding: 38rpx;
  border: 1rpx solid rgba(20, 47, 29, 0.12);
  border-radius: 40rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.95), rgba(248, 250, 247, 0.92)),
    radial-gradient(circle at 20% 8%, rgba(141, 187, 110, 0.18), transparent 34%);
  box-shadow: 0 22rpx 52rpx rgba(20, 47, 29, 0.12);
  box-sizing: border-box;
}

.poster-brand {
  display: block;
  color: #2f6f3e;
  font-size: 24rpx;
  font-weight: 900;
}

.poster-art {
  width: 450rpx;
  height: 450rpx;
  margin: 58rpx auto 34rpx;
}

.poster-title {
  display: block;
  margin-top: 12rpx;
  color: #121512;
  text-align: center;
  font-size: 60rpx;
  font-weight: 900;
}

.poster-look {
  display: block;
  margin-top: 12rpx;
  color: #2f6f3e;
  text-align: center;
  font-size: 24rpx;
  font-weight: 800;
}

.poster-quote {
  display: block;
  margin: 32rpx auto 0;
  color: #121512;
  text-align: center;
  font-size: 39rpx;
  font-weight: 900;
  line-height: 1.5;
}

.poster-foot {
  margin-top: 60rpx;
  color: #6f756d;
  font-size: 24rpx;
  font-weight: 800;
}

.tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  height: calc(112rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.9);
  border-top: 1rpx solid rgba(20, 47, 29, 0.12);
  box-shadow: 0 -12rpx 32rpx rgba(20, 47, 29, 0.08);
  backdrop-filter: blur(18rpx);
}

.tab {
  height: 112rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #6f756d;
  font-size: 26rpx;
  font-weight: 900;
  line-height: normal;
  white-space: nowrap;
}

.tab.active {
  color: #2f6f3e;
  background: rgba(47, 111, 62, 0.06);
}

.bird-shape {
  position: relative;
  width: 138rpx;
  height: 138rpx;
  --bird-main: #8b6b45;
  --bird-belly: #d9c29e;
  --bird-dark: #2d2a24;
  --bird-accent: #c48a45;
  --bird-wing: #6d5639;
  --bird-light: #ffffff;
}

.bird-shape.large {
  width: 230rpx;
  height: 230rpx;
}

.bird-shape.small {
  width: 118rpx;
  height: 118rpx;
}

.bird-shape.poster-bird {
  width: 326rpx;
  height: 326rpx;
}

.bird-body {
  position: absolute;
  left: 16%;
  top: 36%;
  width: 62%;
  height: 45%;
  border-radius: 55% 45% 50% 50%;
  background: var(--bird-main);
  transform: rotate(-12deg);
  z-index: 2;
}

.bird-head {
  position: absolute;
  right: 18%;
  top: 20%;
  width: 32%;
  height: 32%;
  border-radius: 50%;
  background: var(--bird-main);
  z-index: 4;
}

.bird-belly {
  position: absolute;
  left: 31%;
  top: 52%;
  width: 34%;
  height: 25%;
  border-radius: 50%;
  background: var(--bird-belly);
  opacity: 0.95;
  z-index: 3;
}

.bird-wing {
  position: absolute;
  left: 24%;
  top: 48%;
  width: 42%;
  height: 28%;
  border-radius: 50% 50% 55% 45%;
  background: var(--bird-wing);
  opacity: 0.9;
  z-index: 5;
}

.bird-eye {
  position: absolute;
  right: 30%;
  top: 29%;
  width: 7%;
  height: 7%;
  border-radius: 50%;
  background: var(--bird-dark);
  z-index: 9;
}

.bird-beak {
  position: absolute;
  right: 3%;
  top: 32%;
  width: 0;
  height: 0;
  border-top: 12rpx solid transparent;
  border-bottom: 12rpx solid transparent;
  border-left: 34rpx solid var(--bird-accent);
  z-index: 5;
}

.bird-tail {
  position: absolute;
  left: 3%;
  top: 51%;
  width: 32%;
  height: 12%;
  border-radius: 70% 0 0 70%;
  background: var(--bird-wing);
  transform: rotate(-22deg);
  transform-origin: right center;
  z-index: 1;
}

.bird-face,
.bird-crown,
.bird-throat,
.bird-mark,
.bird-leg {
  position: absolute;
  z-index: 7;
}

.bird-face {
  right: 22%;
  top: 24%;
  width: 17%;
  height: 20%;
  border-radius: 50%;
  background: var(--bird-belly);
  opacity: 0.82;
}

.bird-crown {
  right: 24%;
  top: 14%;
  width: 23%;
  height: 14%;
  border-radius: 80% 80% 20% 20%;
  background: var(--bird-dark);
  transform: rotate(-8deg);
}

.bird-throat {
  right: 29%;
  top: 42%;
  width: 15%;
  height: 16%;
  border-radius: 50%;
  background: var(--bird-dark);
}

.bird-mark {
  width: 8%;
  height: 8%;
  border-radius: 50%;
  background: var(--bird-light);
  opacity: 0;
}

.bird-mark.one {
  left: 42%;
  top: 45%;
}

.bird-mark.two {
  left: 52%;
  top: 54%;
}

.bird-mark.three {
  left: 35%;
  top: 58%;
}

.bird-leg {
  top: 78%;
  width: 4%;
  height: 18%;
  border-radius: 999rpx;
  background: var(--bird-dark);
  z-index: 1;
}

.bird-leg.left {
  left: 44%;
}

.bird-leg.right {
  left: 56%;
}

.small-bird .bird-body {
  width: 58%;
  height: 44%;
  left: 19%;
}

.tiny .bird-body {
  width: 52%;
  height: 42%;
  left: 22%;
  top: 38%;
}

.rounded .bird-body,
.duck .bird-body,
.waterbird .bird-body {
  width: 66%;
  height: 48%;
  left: 12%;
  top: 39%;
  border-radius: 58% 42% 48% 52%;
}

.long-tail .bird-tail {
  width: 54%;
  height: 9%;
  left: -18%;
  top: 54%;
  transform: rotate(-13deg);
}

.short-tail .bird-tail {
  width: 22%;
}

.slender .bird-body {
  height: 36%;
  top: 43%;
}

.long-neck .bird-head {
  right: 14%;
  top: 8%;
  width: 26%;
  height: 26%;
}

.long-neck .bird-body {
  left: 22%;
  top: 52%;
  width: 52%;
  height: 34%;
}

.long-neck .bird-throat {
  right: 33%;
  top: 28%;
  width: 11%;
  height: 31%;
  border-radius: 999rpx;
  background: var(--bird-main);
  transform: rotate(-8deg);
  z-index: 3;
}

.long-leg .bird-leg {
  top: 80%;
  height: 30%;
}

.wader .bird-body,
.crane .bird-body,
.ibis .bird-body {
  border-radius: 58% 42% 45% 55%;
}

.raptor .bird-beak,
.parrot .bird-beak {
  right: 4%;
  top: 31%;
  border-top-width: 14rpx;
  border-bottom-width: 7rpx;
  border-left-width: 28rpx;
  transform: rotate(18deg);
}

.raptor .bird-eye {
  width: 8%;
  height: 5%;
  border-radius: 999rpx;
}

.pointed-wing .bird-wing,
.broad-wing .bird-wing {
  left: 17%;
  top: 43%;
  width: 56%;
  height: 29%;
  border-radius: 12% 80% 20% 70%;
  transform: rotate(-10deg);
}

.broad-wing .bird-wing {
  width: 65%;
  height: 36%;
}

.eagle .bird-crown,
.golden-nape .bird-crown {
  background: var(--bird-accent);
  right: 21%;
  top: 22%;
  width: 23%;
  height: 15%;
}

.moustache .bird-mark.one,
.falcon .bird-mark.one {
  opacity: 1;
  right: 25%;
  left: auto;
  top: 36%;
  width: 6%;
  height: 22%;
  border-radius: 999rpx;
  background: var(--bird-dark);
  transform: rotate(18deg);
}

.barred-belly .bird-belly {
  background: repeating-linear-gradient(0deg, var(--bird-belly) 0 8rpx, var(--bird-wing) 8rpx 12rpx);
}

.spotted .bird-mark,
.spotted-neck .bird-mark,
